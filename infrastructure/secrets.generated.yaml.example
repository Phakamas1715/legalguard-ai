# AWS Secrets Manager generated secrets example for LegalGuard AI
# Copy this to secrets.generated.yaml and fill in the values

secrets:
  # AWS Bedrock API Keys & Config
  - name: "legalguard/bedrock/credentials"
    values:
      aws_access_key_id: "YOUR_ACCESS_KEY"
      aws_secret_access_key: "YOUR_SECRET_KEY"
      aws_region: "us-east-1"

  # Database Credentials (Aurora PostgreSQL)
  - name: "legalguard/db/primary"
    values:
      username: "legalguard_admin"
      password: "STRONG_PASSWORD_HERE"
      host: "legalguard-db.cluster-xxxx.us-east-1.rds.amazonaws.com"
      port: "5432"
      dbname: "legalguard_prod"

  # Supabase Integration (if used for Auth/Edge Functions)
  - name: "legalguard/supabase/config"
    values:
      url: "https://your-project.supabase.co"
      anon_key: "eyJhbG..."
      service_role_key: "eyJhbG..."

  # National Security Audit Chain (CAL-130) Keys
  - name: "legalguard/audit/hmac-key"
    values:
      key: "CHANGE_ME_TO_A_64_CHAR_HEX_STRING"

  # PII Masking Configuration
  - name: "legalguard/pii/salt"
    values:
      salt: "RANDOM_SALT_FOR_PII_HASHING"
