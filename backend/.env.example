# ============================================================
# LegalGuard AI — Backend Environment Variables (TEMPLATE)
# Copy this file to backend/.env and fill in your values.
# Never commit backend/.env — it is gitignored.
# ============================================================

# --- LLM Providers ------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Zhipu AI — GLM-4-plus (ChatGLM)
GLM_API_KEY=your-glm-api-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-plus

# Typhoon (Thai LLM — SCB 10X, optional fallback)
# Register free at https://opentyphoon.ai
TYPHOON_API_KEY=
TYPHOON_BASE_URL=https://api.opentyphoon.ai/v1
TYPHOON_MODEL=typhoon-v2-70b-instruct
TYPHOON_EMBED_MODEL=typhoon-v2-embed-multilingual

# LLM provider selection: bedrock | anthropic | glm | typhoon
LLM_PROVIDER=bedrock

# --- AWS / Bedrock ------------------------------------------
# Primary region for Bedrock (ap-southeast-1 = Singapore)
AWS_REGION=ap-southeast-1
# Bearer token from AWS console (Bedrock API key) — expires when revoked
AWS_BEARER_TOKEN_BEDROCK=your-bedrock-bearer-token
# Optional: IAM access key pair (alternative to bearer token)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_ACCOUNT_ID=your-aws-account-id

# --- Hugging Face -------------------------------------------
# Get token at https://huggingface.co/settings/tokens (read scope is enough)
HUGGINGFACE_TOKEN=hf_xxxxx

# --- Vector Database (Qdrant) -------------------------------
# Local: docker run -p 6333:6333 qdrant/qdrant
# Cloud: https://cloud.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Cache (Redis) ------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Geocoder (traccar-geocoder — self-hosted OSM reverse geocoding) ----
GEOCODER_URL=http://localhost:3001
GEOCODER_API_KEY=legalguard

# --- Application --------------------------------------------
APP_ENV=development
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:4173

# --- Authentication (set AUTH_ENABLED=true for production) ---
AUTH_ENABLED=false
AUTH_SECRET=change-this-to-a-random-secret-in-production
RATE_LIMIT_PER_MINUTE=120
