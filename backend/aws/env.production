# Production environment variables for AWS deployment
# Copy to .env on the deployment target or use AWS Secrets Manager

# LLM & Embeddings — use Bedrock (data stays in AWS)
EMBEDDING_PROVIDER=bedrock
AWS_REGION=ap-southeast-1

# Aurora PostgreSQL (pgvector enabled)
DATABASE_URL=postgresql://legalguard:CHANGE_ME@aurora-cluster.cluster-xxx.ap-southeast-1.rds.amazonaws.com:5432/legalguard

# ElastiCache Redis
REDIS_URL=redis://legalguard-cache.xxx.ap-southeast-1.cache.amazonaws.com:6379/0

# Qdrant (self-hosted on EKS or use Aurora pgvector instead)
QDRANT_URL=http://qdrant-svc.legalguard:6333
QDRANT_API_KEY=

# BM25 Index (persistent volume on EKS)
BM25_INDEX_PATH=/data/bm25_index

# Anthropic Claude API (via Bedrock — no direct key needed)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Application
APP_ENV=production
CORS_ORIGINS=https://legalguard.example.com
LOG_LEVEL=info

# Supabase (if still using Edge Functions as proxy)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxx

# Bedrock Guardrails
BEDROCK_GUARDRAIL_ID=your-guardrail-id

# Ollama fallback (local LLM on EKS)
OLLAMA_URL=http://ollama-svc.legalguard:11434
