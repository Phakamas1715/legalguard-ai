# ============================================================
# LegalGuard AI — Frontend Environment Variables (TEMPLATE)
# Copy this file to .env and fill in your values.
# Only VITE_ prefixed variables are bundled into the browser.
# Never put secret API keys here — frontend is public.
# ============================================================

# Supabase (get from https://supabase.com/dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJxxxxx

# Backend API URL
VITE_API_URL=http://localhost:8000
